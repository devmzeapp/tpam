// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

// ==================== USER MANAGEMENT ====================

enum UserRole {
  SUPER_ADMIN
  ADMIN
  AGENT
  COMPTABLE
  LECTURE
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(AGENT)
  companyId String?
  active    Boolean  @default(true)
  approved  Boolean  @default(false) // Requires super admin approval
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  services  Service[]
  invoices  Invoice[]
  manifests Manifest[]
  company   Company?  @relation(fields: [companyId], references: [id])
}

// ==================== COMPANIES ====================

model Company {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  phone       String?
  address     String?
  city        String?
  ice         String?  // Identifiant Commun de l'Entreprise
  rc          String?  // Registre de Commerce
  if          String?  // Identifiant Fiscal
  cnss        String?  // CNSS
  logo        String?  // Logo de l'entreprise (base64 ou URL)
  stamp       String?  // Cachet (base64 ou URL)
  signature   String?  // Signature (base64 ou URL)
  active      Boolean  @default(true)
  approved    Boolean  @default(false) // Requires super admin approval
  blocked     Boolean  @default(false) // Blocked for non-payment or other reasons
  blockReason String? // Reason for blocking
  plan        String   @default("trial") // trial, starter, professional, enterprise
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users User[]
}

// ==================== VEHICLES ====================

model Vehicle {
  id             String   @id @default(cuid())
  brand          String
  model          String
  registration   String   @unique
  capacity       Int
  type           String?
  status         String   @default("available")
  notes          String?
  
  // Kilométrage et maintenance
  currentKm          Int?
  lastOilChangeDate  DateTime?
  lastOilChangeKm    Int?
  nextOilChangeKm    Int?     // Calculé automatiquement ou saisi
  
  // Documents administratifs
  insuranceExpiry            DateTime?
  vignetteExpiry             DateTime?
  technicalInspectionExpiry  DateTime?
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  services       Service[]
  manifests      Manifest[]
}

// ==================== DRIVERS ====================

model Driver {
  id            String   @id @default(cuid())
  firstName     String
  lastName      String
  phone         String
  email         String?
  licenseNumber String?
  available     Boolean  @default(true)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  services    Service[]
  manifests   Manifest[]
}

// ==================== CLIENTS ====================

model Client {
  id           String   @id @default(cuid())
  name         String
  contactName  String?
  email        String?
  phone        String?
  address      String?
  city         String?
  ice          String?
  cnss         String?
  if           String?
  rc           String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  services   Service[]
  invoices   Invoice[]
  payments   Payment[]
}

// ==================== SERVICES/PRESTATIONS ====================

enum ServiceStatus {
  NON_DECLAREE
  PRO_FORMA
  FACTUREE
}

enum ServiceType {
  TRANSFERT
  EXCURSION
  LOCATION
  TRANSPORT
  AUTRE
}

model Service {
  id              String        @id @default(cuid())
  clientId        String
  vehicleId       String
  driverId        String
  createdById     String
  type            ServiceType   @default(TRANSFERT)
  description     String?
  date            DateTime
  endTime         DateTime?
  departurePlace  String
  arrivalPlace    String
  passengerCount  Int           @default(1)
  passengerNames  String?
  price           Float
  currency        String        @default("MAD")
  status          ServiceStatus @default(NON_DECLAREE)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  client        Client        @relation(fields: [clientId], references: [id])
  vehicle       Vehicle       @relation(fields: [vehicleId], references: [id])
  driver        Driver        @relation(fields: [driverId], references: [id])
  createdBy     User          @relation(fields: [createdById], references: [id])
  invoiceItems  InvoiceItem[]
  manifests     Manifest[]
}

// ==================== INVOICES ====================

enum InvoiceType {
  PRO_FORMA
  FINALE
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  CANCELLED
}

model Invoice {
  id          String        @id @default(cuid())
  number      String        @unique
  clientId    String
  createdById String
  type        InvoiceType   @default(FINALE)
  status      InvoiceStatus @default(DRAFT)
  issueDate   DateTime      @default(now())
  dueDate     DateTime?
  paidDate    DateTime?
  subtotal    Float         @default(0)
  taxRate     Float         @default(0)
  taxAmount   Float         @default(0)
  total       Float         @default(0)
  currency    String        @default("MAD")
  notes       String?
  terms       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  client    Client        @relation(fields: [clientId], references: [id])
  createdBy User          @relation(fields: [createdById], references: [id])
  items     InvoiceItem[]
  payments  Payment[]
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  serviceId   String
  description String
  quantity    Int      @default(1)
  unitPrice   Float
  total       Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id])
}

// ==================== PAYMENTS ====================

enum PaymentMethod {
  ESPECES
  VIREMENT
  CHEQUE
  CARTE
}

model Payment {
  id          String        @id @default(cuid())
  clientId    String
  invoiceId   String?
  amount      Float
  currency    String        @default("MAD")
  method      PaymentMethod @default(ESPECES)
  reference   String?
  paymentDate DateTime      @default(now())
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  client  Client   @relation(fields: [clientId], references: [id])
  invoice Invoice? @relation(fields: [invoiceId], references: [id])
}

// ==================== MANIFESTS ====================

model Manifest {
  id              String   @id @default(cuid())
  serviceId       String
  vehicleId       String
  driverId        String
  createdById     String
  date            DateTime
  departurePlace  String
  arrivalPlace    String
  departureTime   String?
  arrivalTime     String?
  passengerCount  Int      @default(1)
  passengerList   String?
  remarks         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  service    Service @relation(fields: [serviceId], references: [id])
  vehicle    Vehicle @relation(fields: [vehicleId], references: [id])
  driver     Driver  @relation(fields: [driverId], references: [id])
  createdBy  User    @relation(fields: [createdById], references: [id])
}

// ==================== SETTINGS ====================

model Setting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
