// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

// ==================== TENANT ACCOUNT (COMPTE CLIENT) ====================

// Chaque TenantAccount représente un client/entreprise qui a son propre espace isolé
model TenantAccount {
  id              String   @id @default(cuid())
  name            String                    // Nom de l'entreprise/client
  slug            String   @unique          // Identifiant unique pour l'URL
  email           String   @unique          // Email principal
  phone           String?
  address         String?
  city            String?
  
  // Informations légales
  ice             String?  // Identifiant Commun de l'Entreprise
  rc              String?  // Registre de Commerce
  if              String?  // Identifiant Fiscal
  cnss            String?  // CNSS
  
  // Branding
  logo            String?  // Logo (base64 ou URL)
  stamp           String?  // Cachet (base64 ou URL)
  signature       String?  // Signature (base64 ou URL)
  
  // Gestion du compte
  plan            String   @default("trial") // trial, starter, professional, enterprise
  active          Boolean  @default(true)
  approved        Boolean  @default(false)    // Approuvé par super_admin
  blocked         Boolean  @default(false)    // Bloqué pour non-paiement ou autre
  blockReason     String?
  
  // Dates
  trialEndsAt     DateTime?
  subscriptionEndsAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations - toutes les données appartiennent à ce tenant
  users           User[]
  vehicles        Vehicle[]
  drivers         Driver[]
  clients         Client[]
  services        Service[]
  invoices        Invoice[]
  payments        Payment[]
  manifests       Manifest[]
  settings        TenantSetting[]
}

// ==================== USER MANAGEMENT ====================

enum UserRole {
  SUPER_ADMIN     // Admin global - gère tous les tenants
  ADMIN_CLIENT    // Admin d'un tenant - gère son espace uniquement
  ADMIN           // Ancien rôle, à migrer vers ADMIN_CLIENT
  AGENT           // Agent du tenant
  COMPTABLE       // Comptable du tenant
  LECTURE         // Lecture seule
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String
  name        String
  role        UserRole @default(AGENT)
  
  // Lien vers le tenant (obligatoire sauf pour SUPER_ADMIN)
  tenantId    String?
  
  // Statut
  active      Boolean  @default(true)
  approved    Boolean  @default(false) // Approuvé par admin_client ou super_admin
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  tenant      TenantAccount? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  services    Service[]
  invoices    Invoice[]
  manifests   Manifest[]
  
  // Index pour les performances
  @@index([tenantId])
  @@index([email])
}

// ==================== VEHICLES ====================

model Vehicle {
  id              String   @id @default(cuid())
  tenantId        String                      // Appartient au tenant
  
  brand           String
  model           String
  registration    String
  capacity        Int
  type            String?
  status          String   @default("available")
  notes           String?
  
  // Kilométrage et maintenance
  currentKm          Int?
  lastOilChangeDate  DateTime?
  lastOilChangeKm    Int?
  nextOilChangeKm    Int?
  
  // Documents administratifs
  insuranceExpiry            DateTime?
  vignetteExpiry             DateTime?
  technicalInspectionExpiry  DateTime?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  tenant      TenantAccount @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  services    Service[]
  manifests   Manifest[]
  
  // Index unique pour l'immatriculation par tenant
  @@unique([tenantId, registration])
  @@index([tenantId])
  @@index([status])
}

// ==================== DRIVERS ====================

model Driver {
  id            String   @id @default(cuid())
  tenantId      String                      // Appartient au tenant
  
  firstName     String
  lastName      String
  phone         String
  email         String?
  licenseNumber String?
  available     Boolean  @default(true)
  notes         String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  tenant      TenantAccount @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  services    Service[]
  manifests   Manifest[]
  
  // Index
  @@index([tenantId])
  @@index([available])
}

// ==================== CLIENTS (Clients finaux du tenant) ====================

model Client {
  id            String   @id @default(cuid())
  tenantId      String                      // Appartient au tenant
  
  name          String
  contactName   String?
  email         String?
  phone         String?
  address       String?
  city          String?
  ice           String?
  cnss          String?
  if            String?
  rc            String?
  notes         String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  tenant      TenantAccount @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  services    Service[]
  invoices    Invoice[]
  payments    Payment[]
  
  // Index
  @@index([tenantId])
  @@index([name])
}

// ==================== SERVICES/PRESTATIONS ====================

enum ServiceStatus {
  NON_DECLAREE
  PRO_FORMA
  FACTUREE
}

enum ServiceType {
  TRANSFERT
  EXCURSION
  LOCATION
  TRANSPORT
  AUTRE
}

model Service {
  id              String        @id @default(cuid())
  tenantId        String                          // Appartient au tenant
  
  clientId        String
  vehicleId       String
  driverId        String
  createdById     String
  
  type            ServiceType   @default(TRANSFERT)
  description     String?
  date            DateTime
  endTime         DateTime?
  departurePlace  String
  arrivalPlace    String
  passengerCount  Int           @default(1)
  passengerNames  String?
  price           Float
  currency        String        @default("MAD")
  status          ServiceStatus @default(NON_DECLAREE)
  notes           String?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  tenant        TenantAccount @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client        Client        @relation(fields: [clientId], references: [id], onDelete: Restrict)
  vehicle       Vehicle       @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  driver        Driver        @relation(fields: [driverId], references: [id], onDelete: Restrict)
  createdBy     User          @relation(fields: [createdById], references: [id], onDelete: Restrict)
  invoiceItems  InvoiceItem[]
  manifests     Manifest[]
  
  // Index
  @@index([tenantId])
  @@index([clientId])
  @@index([vehicleId])
  @@index([driverId])
  @@index([date])
  @@index([status])
}

// ==================== INVOICES ====================

enum InvoiceType {
  PRO_FORMA
  FINALE
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  CANCELLED
}

model Invoice {
  id            String        @id @default(cuid())
  tenantId      String                          // Appartient au tenant
  
  number        String
  clientId      String
  createdById   String
  
  type          InvoiceType   @default(FINALE)
  status        InvoiceStatus @default(DRAFT)
  issueDate     DateTime      @default(now())
  dueDate       DateTime?
  paidDate      DateTime?
  
  subtotal      Float         @default(0)
  taxRate       Float         @default(0)
  taxAmount     Float         @default(0)
  total         Float         @default(0)
  currency      String        @default("MAD")
  
  notes         String?
  terms         String?
  
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations
  tenant      TenantAccount @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client      Client        @relation(fields: [clientId], references: [id], onDelete: Restrict)
  createdBy   User          @relation(fields: [createdById], references: [id], onDelete: Restrict)
  items       InvoiceItem[]
  payments    Payment[]
  
  // Numéro de facture unique par tenant
  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([clientId])
  @@index([status])
  @@index([issueDate])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  serviceId   String
  
  description String
  quantity    Int      @default(1)
  unitPrice   Float
  total       Float
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  
  // Index
  @@index([invoiceId])
  @@index([serviceId])
}

// ==================== PAYMENTS ====================

enum PaymentMethod {
  ESPECES
  VIREMENT
  CHEQUE
  CARTE
}

model Payment {
  id          String        @id @default(cuid())
  tenantId    String                          // Appartient au tenant
  
  clientId    String
  invoiceId   String?
  
  amount      Float
  currency    String        @default("MAD")
  method      PaymentMethod @default(ESPECES)
  reference   String?
  paymentDate DateTime      @default(now())
  notes       String?
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  tenant    TenantAccount @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client    Client        @relation(fields: [clientId], references: [id], onDelete: Restrict)
  invoice   Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  
  // Index
  @@index([tenantId])
  @@index([clientId])
  @@index([invoiceId])
  @@index([paymentDate])
}

// ==================== MANIFESTS ====================

model Manifest {
  id              String   @id @default(cuid())
  tenantId        String                      // Appartient au tenant
  
  serviceId       String
  vehicleId       String
  driverId        String
  createdById     String
  
  date            DateTime
  departurePlace  String
  arrivalPlace    String
  departureTime   String?
  arrivalTime     String?
  passengerCount  Int      @default(1)
  passengerList   String?
  remarks         String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  tenant      TenantAccount @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  service     Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  vehicle     Vehicle       @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  driver      Driver        @relation(fields: [driverId], references: [id], onDelete: Restrict)
  createdBy   User          @relation(fields: [createdById], references: [id], onDelete: Restrict)
  
  // Index
  @@index([tenantId])
  @@index([serviceId])
  @@index([date])
}

// ==================== TENANT SETTINGS ====================

model TenantSetting {
  id          String   @id @default(cuid())
  tenantId    String                      // Appartient au tenant
  
  key         String
  value       String
  description String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  tenant  TenantAccount @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Clé unique par tenant
  @@unique([tenantId, key])
  @@index([tenantId])
}

// ==================== GLOBAL SETTINGS (Super Admin only) ====================

model GlobalSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== MIGRATION HELPER ====================

// Ancien modèle Company pour la migration - sera supprimé après migration
// Note: les données sont migrées vers TenantAccount
model Company {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  phone       String?
  address     String?
  city        String?
  ice         String?
  rc          String?
  if          String?
  cnss        String?
  logo        String?
  stamp       String?
  signature   String?
  active      Boolean  @default(true)
  approved    Boolean  @default(false)
  blocked     Boolean  @default(false)
  blockReason String?
  plan        String   @default("trial")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
