// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== USER MANAGEMENT ====================

enum UserRole {
  ADMIN
  AGENT
  COMPTABLE
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(AGENT)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  services  Service[]
  invoices  Invoice[]
  manifests Manifest[]
}

// ==================== VEHICLES ====================

model Vehicle {
  id             String   @id @default(cuid())
  brand          String   // Marque
  model          String   // Modèle
  registration   String   @unique // Immatriculation
  capacity       Int      // Capacité passagers
  type           String?  // Type de véhicule (van, bus, berline, etc.)
  status         String   @default("available") // available, in_mission, maintenance
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  services       Service[]
  manifests      Manifest[]
}

// ==================== DRIVERS ====================

model Driver {
  id           String   @id @default(cuid())
  firstName    String
  lastName     String
  phone        String
  email        String?
  licenseNumber String?
  available    Boolean  @default(true)
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  services     Service[]
  manifests    Manifest[]
}

// ==================== CLIENTS ====================

model Client {
  id           String   @id @default(cuid())
  name         String   // Nom / Raison sociale
  contactName  String?  // Contact principal
  email        String?
  phone        String?
  address      String?
  city         String?
  
  // Informations fiscales (Maroc)
  ice          String?  // Identifiant Commun de l'Entreprise
  cnss         String?  // Numéro CNSS
  if           String?  // Identifiant Fiscal
  rc           String?  // Registre de Commerce
  
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  services     Service[]
  invoices     Invoice[]
  payments     Payment[]
}

// ==================== SERVICES/PRESTATIONS ====================

enum ServiceStatus {
  NON_DECLAREE    // Non déclarée
  PRO_FORMA       // Pro forma
  FACTUREE        // Facturée
}

enum ServiceType {
  TRANSFERT       // Transfert aéroport/gare
  EXCURSION       // Excursion touristique
  LOCATION        // Location avec chauffeur
  TRANSPORT       // Transport de groupe
  AUTRE           // Autre
}

model Service {
  id              String        @id @default(cuid())
  clientId        String
  vehicleId       String
  driverId        String
  createdById     String
  
  // Détails de la prestation
  type            ServiceType   @default(TRANSFERT)
  description     String?
  
  // Date et heure
  date            DateTime
  endTime         DateTime?
  
  // Trajet
  departurePlace  String        // Lieu de départ
  arrivalPlace    String        // Lieu d'arrivée
  
  // Passagers
  passengerCount  Int           @default(1)
  passengerNames  String?       // Noms des passagers
  
  // Prix
  price           Float
  currency        String        @default("MAD")
  
  // Statut
  status          ServiceStatus @default(NON_DECLAREE)
  
  // Notes
  notes           String?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  client          Client        @relation(fields: [clientId], references: [id])
  vehicle         Vehicle       @relation(fields: [vehicleId], references: [id])
  driver          Driver        @relation(fields: [driverId], references: [id])
  createdBy       User          @relation(fields: [createdById], references: [id])
  invoiceItems    InvoiceItem[]
  manifests       Manifest[]
}

// ==================== INVOICES ====================

enum InvoiceType {
  PRO_FORMA
  FINALE
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  CANCELLED
}

model Invoice {
  id              String        @id @default(cuid())
  number          String        @unique // Numéro de facture (XXX-AAAA)
  clientId        String
  createdById     String
  
  type            InvoiceType   @default(FINALE)
  status          InvoiceStatus @default(DRAFT)
  
  // Dates
  issueDate       DateTime      @default(now())
  dueDate         DateTime?
  paidDate        DateTime?
  
  // Montants
  subtotal        Float         @default(0)
  taxRate         Float         @default(0)
  taxAmount       Float         @default(0)
  total           Float         @default(0)
  currency        String        @default("MAD")
  
  // Notes
  notes           String?
  terms           String?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  client          Client        @relation(fields: [clientId], references: [id])
  createdBy       User          @relation(fields: [createdById], references: [id])
  items           InvoiceItem[]
  payments        Payment[]
}

model InvoiceItem {
  id              String   @id @default(cuid())
  invoiceId       String
  serviceId       String
  
  description     String
  quantity        Int      @default(1)
  unitPrice       Float
  total           Float
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  invoice         Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  service         Service  @relation(fields: [serviceId], references: [id])
}

// ==================== PAYMENTS ====================

enum PaymentMethod {
  ESPECES
  VIREMENT
  CHEQUE
  CARTE
}

model Payment {
  id              String        @id @default(cuid())
  clientId        String
  invoiceId       String?
  
  amount          Float
  currency        String        @default("MAD")
  method          PaymentMethod @default(ESPECES)
  reference       String?       // Référence du paiement
  
  paymentDate     DateTime      @default(now())
  notes           String?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  client          Client        @relation(fields: [clientId], references: [id])
  invoice         Invoice?      @relation(fields: [invoiceId], references: [id])
}

// ==================== MANIFESTS ====================

model Manifest {
  id              String   @id @default(cuid())
  serviceId       String
  vehicleId       String
  driverId        String
  createdById     String
  
  // Informations du voyage
  date            DateTime
  departurePlace  String
  arrivalPlace    String
  departureTime   String?
  arrivalTime     String?
  
  // Passagers
  passengerCount  Int      @default(1)
  passengerList   String?  // Liste des passagers (JSON ou texte)
  
  // Remarques
  remarks         String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  service         Service  @relation(fields: [serviceId], references: [id])
  vehicle         Vehicle  @relation(fields: [vehicleId], references: [id])
  driver          Driver   @relation(fields: [driverId], references: [id])
  createdBy       User     @relation(fields: [createdById], references: [id])
}

// ==================== SETTINGS ====================

model Setting {
  id              String   @id @default(cuid())
  key             String   @unique
  value           String
  description     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
